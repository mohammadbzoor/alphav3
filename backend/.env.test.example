NODE_ENV=test
PORT=3001
API_PREFIX=/api/v1

# ==========================================
# MySQL Database (Test Isolation)
# ==========================================

DB_HOST=localhost
DB_PORT=3306
DB_NAME=alpha_test
DB_USER=alpha_app_test
DB_PASSWORD=replace_with_test_password
DB_CONNECTION_LIMIT=10

# ==========================================
# JWT Authentication
# ==========================================

JWT_ACCESS_SECRET=test_access_secret
JWT_REFRESH_SECRET=test_refresh_secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d

# ==========================================
# External Webhooks
# ==========================================
N8N_OTP_WEBHOOK_URL=http://localhost:9999/webhook/OTP
N8N_WEBHOOK_URL=http://localhost:9999/webhook/transaction

# ==========================================
# Other Settings
# ==========================================
BCRYPT_SALT_ROUNDS=4
LOG_LEVEL=error
